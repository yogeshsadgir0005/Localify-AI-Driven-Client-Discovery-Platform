# Copy to .env and fill in. NEVER commit the real .env.
# Setup walkthrough for every free credential below: docs/FREE_SETUP_GUIDE.md
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/localbiz
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
FRONTEND_URL=http://localhost:5173

# Google — OAuth login (free) + Places for the discovery seed.
GOOGLE_CLIENT_ID=

GOOGLE_MAPS_API_KEY=
# Max billable Google Places requests per UTC day (0 disables the cap).
GOOGLE_PLACES_DAILY_CAP=2500

# Free LLM — Groq (hosts open-source Llama models; OpenAI-compatible API).
# Free key: https://console.groq.com → API Keys. Blank = heuristic fallbacks only.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# Email — Brevo (OTP delivery + notifications, free 300/day).
# Free key: https://app.brevo.com → SMTP & API → API Keys.
# EMAIL_FROM must be a sender you verified in Brevo. Blank = dev-console OTP.
BREVO_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=Setu

# DPDP grievance officer (surfaced at GET /api/legal/privacy)
GRIEVANCE_OFFICER_NAME=
GRIEVANCE_OFFICER_EMAIL=

# Moderation
ADMIN_EMAILS=
REPORT_REVIEW_THRESHOLD=2

# Optional PAID hosted-Claude escalation — OFF by default, NOT needed for the
# free stack. Only enable if you deliberately add a paid provider later.
HOSTED_LLM_ENABLED=false
ANTHROPIC_API_KEY=
HOSTED_LLM_MODEL=claude-opus-4-8
HOSTED_LLM_DAILY_CAP=200

# Optional semantic search (free, off by default) — needs a free Jina key
# (https://jina.ai/embeddings). Leave disabled to stay on lexical matching.
EMBEDDINGS_ENABLED=false
JINA_API_KEY=
EMBED_MODEL=jina-embeddings-v3

# Optional: auto-expire raw telemetry events after N days (unset = keep all)
# EVENT_RETENTION_DAYS=180

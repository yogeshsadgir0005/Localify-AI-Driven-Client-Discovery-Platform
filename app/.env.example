# Point the app at your backend (the SAME server the website uses).
# - Android emulator: use http://10.0.2.2:5000/api
# - iOS simulator:    use http://localhost:5000/api
# - Physical device:  use your computer's LAN IP, e.g. http://192.168.1.5:5000/api
# - Production:        use your deployed backend, e.g. https://your-backend.onrender.com/api
EXPO_PUBLIC_API_BASE_URL=http://172.20.10.6:5000/api

# --- Google Sign-In (optional) ---------------------------------------------
# The "Continue with Google" button only appears when the WEB client id is set.
# Create OAuth client IDs in Google Cloud Console (all under the SAME project):
#   - Web client id      → EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID (also set as the
#                          server's GOOGLE_CLIENT_ID so token audiences match)
#   - iOS client id      → EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID (dev/standalone iOS)
#   - Android client id  → EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID (dev/standalone Android)
# Note: Google's OAuth redirect rules mean the flow completes reliably in a
# development/standalone build; email+password works everywhere including Expo Go.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=